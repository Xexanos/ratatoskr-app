# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# Android build outputs
*.apk
*.aab
*.ap_
*.dex
release/
captures/

# Local configuration
local.properties
keystore.properties
*.keystore
*.jks

# Android Studio / IntelliJ
.idea/
*.iml
.DS_Store

# Installed skills (third-party local tooling, not project code). Our own project
# skills and agents ARE committed -- installed skills are re-excluded per entry below.
# skills-lock.json IS committed: it records the installed third-party skills (source +
# content hash) so they stay reproducible without vendoring their files.
.claude/skills/*
!.claude/skills/ux-review/

# Personal, machine-local settings (plugin toggles, etc.). The shared, committed config
# lives in .claude/settings.json; this override file must never be committed.
.claude/settings.local.json

# Font cache of the logo generator. The Norse font license forbids
# redistributing the font FILE, so it is downloaded from the author's
# site on demand and must never be committed.
tools/logo/.fontcache/

# Logs
*.log

# Generated API client (generated at build time from the OpenAPI contract; never
# committed -- see SPEC section 4). AGP writes it under core-network/build
# (generate-resources/), already covered by the build/ rule above; listed explicitly
# for clarity.
core-network/build/generate-resources/
